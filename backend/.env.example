# Server
PORT=4000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mini-social-feed?retryWrites=true&w=majority

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Firebase Cloud Messaging (optional — push disabled if unset)
# Base64-encoded contents of the Firebase service account JSON:
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
#   bash:       base64 -w0 service-account.json
FIREBASE_SERVICE_ACCOUNT_BASE64=

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=*
